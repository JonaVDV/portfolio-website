{
	"name": "frontend",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vp dev",
		"build": "vp build",
		"preview": "vp preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "vp fmt --write && prettier --write 'src/**/*.svelte'",
		"lint": "vp lint && eslint ."
	},
	"devDependencies": {
		"@eslint/compat": "^1.4.0",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/node": "^24",
		"eslint": "^9.38.0",
		"eslint-plugin-oxlint": "^1.57.0",
		"eslint-plugin-svelte": "^3.12.4",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"svelte": "^5.49.1",
		"svelte-check": "^4.3.3",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.46.3",
		"vite": "catalog:",
		"vite-plus": "catalog:",
		"zimmerframe": "^1.1.4",
		"zod": "^4.1.12"
	}
}
